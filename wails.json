{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "Markmiru",
  "outputfilename": "Markmiru",
  "frontend:install": "npm ci",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "postBuildHooks": {
    "darwin/*": "cp ../darwin/iconfile.icns Markmiru.app/Contents/Resources/iconfile.icns"
  },
  "info": {
    "companyName": "Markmiru",
    "productName": "Markmiru",
    "productVersion": "dev",
    "copyright": "",
    "comments": "Markdown viewer/editor"
  },
  "author": {
    "name": "",
    "email": ""
  }
}
